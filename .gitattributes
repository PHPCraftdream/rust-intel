# Disable git's "LF will be replaced by CRLF" warning on Windows.
# Working text is LF-canonical (committed blobs use \n). The explicit
# eol=lf below tells git to leave line endings alone — what is on disk
# is what gets committed. Windows-only file types (.ps1, .bat) keep
# CRLF because cmd.exe and PowerShell parsers require it.
* text=auto eol=lf

# Shell scripts — always LF (bash on Windows via Git Bash also expects LF).
*.sh text eol=lf
*.bash text eol=lf

# Windows-native scripts — CRLF or cmd.exe misparses them.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Lockfiles and configs — normalised to LF on commit even if a Windows
# editor saved CRLF.
*.toml  text eol=lf
*.lock  text eol=lf
*.json  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.md    text eol=lf
*.rs    text eol=lf

# Generated / minified web bundles — leave bytes alone.
*.min.js binary
*.min.css binary

# Binary fixtures, snapshots, certificates — never touch.
*.png binary
*.jpg binary
*.pdf binary
*.snap binary
*.der binary
